

#include <iostream>
#include<vector>
using namespace std;
void power(int index,int n,int arr[],vector<int>curr,vector<vector<int>>&ans){
    if(index==n){
        ans.push_back(curr);
        return;
    }
    power(index+1,n,arr,curr,ans);
    curr.push_back(arr[index]);
    power(index+1,n,arr,curr,ans);
}
int main()
{
    int n;
    cin>>n;
    int *arr=new int[n];
    for(int i=0;i<n;i++)
    cin>>arr[i];
    vector<int>curr;
    vector<vector<int>>ans;
    power(0,n,arr,curr,ans);
    for(auto vec:ans){
        for(auto ele :vec){
            cout<<ele<<" ";
        }
        cout<<endl;
    }

    return 0;
}
